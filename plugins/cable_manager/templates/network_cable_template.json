{
  "template_id": "network_cable_template",
  "display_name": "Ethernet / Network Cable",
  "belong_to_plugin": "cable_manager",
  "schema": {
    "type": "object",
    "required": ["category", "length_meters"],
    "properties": {
      "category": {
        "type": "string",
        "title": "Cable Category",
        "enum": ["Cat5e", "Cat6", "Cat6a", "Cat7", "Cat8", "Fiber Patch"],
        "description": "Select the Ethernet speed standard"
      },
      "length_meters": {
        "type": "number",
        "title": "Length (meters)",
        "description": "e.g., 0.5, 1, 3, 5, 15"
      },
      "head_tail_type": {
        "type": "string",
        "title": "Connector Type",
        "default": "RJ45 to RJ45",
        "description": "Default is RJ45, or LC-LC for fiber"
      },
      "color": {
        "type": ["string", "null"],
        "title": "Color",
        "default": "Blue"
      },
      "shielding_type": {
        "type": "string",
        "title": "Shielding (Advanced Note)",
        "enum": ["UTP (Unshielded)", "FTP/STP (Shielded)", "Unknown"],
        "default": "Unknown",
        "ui_group": "advanced_notes"
      },
      "current_status": {
        "type": "string",
        "title": "Status Note (Advanced Note)",
        "description": "e.g., Connected to Switch, Spare in server rack rack",
        "ui_group": "advanced_notes"
      }
    }
  }
}